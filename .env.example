# RPA4All Nextcloud fork defaults
# Sem necessidade de configuração de URL manual para o cenário RPA4All.

RPA4ALL_DOMAIN=rpa4all.com
NEXTCLOUD_SUBDOMAIN=nextcloud
AUTHENTIK_SUBDOMAIN=auth

NEXTCLOUD_IMAGE=nextcloud:29-apache
MARIADB_IMAGE=mariadb:11
REDIS_IMAGE=redis:7-alpine

NEXTCLOUD_PORT=8880
NEXTCLOUD_CONTAINER=nextcloud-rpa4all

MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me

NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-admin-me

# Authentik API token para scripts de provisionamento/sync
AUTHENTIK_TOKEN=
AUTHENTIK_VERIFY_TLS=true

# Credenciais OIDC usadas no provider do Nextcloud
AUTHENTIK_NEXTCLOUD_CLIENT_ID=authentik-nextcloud
AUTHENTIK_NEXTCLOUD_CLIENT_SECRET=change-nextcloud-oidc-secret

# Geração do fundo (mesma lógica do RPA4All.com)
RPA4ALL_BG_API_BASE=https://api.rpa4all.com/agents-api
RPA4ALL_BG_MODEL=phi4-mini:latest
